# --- Database ---
DATABASE_URL=

# --- Dashboard ---
DASHBOARD_PIN=

# --- Email (Resend) ---
RESEND_API_KEY=
CREATOR_EMAIL=

# --- AI Providers ---
# Premium / visitor-facing layer (concierge, brand_strategy, premium_consultation,
# emotional_support, executive_copy)
OPENAI_API_KEY=

# Automation / scale layer (seo, social, content_generation, automation, coding,
# digest, followup, session_summary). Falls back to OpenAI when missing or on error.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional routing overrides
# Default provider for premium tasks (concierge, brand_strategy, executive_copy, etc.).
# NOTE: Premium brand copy types (newsletter, executive_copy, etc.) are ALSO hard-locked to OpenAI in code
# via providerOverride — they cannot drift to DeepSeek even if this value is changed.
AI_PREMIUM_PROVIDER=openai
AI_AUTOMATION_PROVIDER=deepseek

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# One-time price ID for the AI Growth Strategy Session ($97). When unset,
# POST /api/checkout/strategy-session returns 503 (checkout disabled).
STRIPE_PRICE_STRATEGY_SESSION=

# --- Optional public config ---
WHATSAPP_NUMBER=
ANNOUNCEMENT_TEXT=
ANNOUNCEMENT_URL=
